#include <windows.h>

// Icone do executavel (Explorer, barra de tarefas). O ID 1 (menor) e o que o
// Windows usa como icone do .exe.
1 ICON "assets\\logo.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "041604b0"   // PT-BR, Unicode
        BEGIN
            VALUE "CompanyName",      "Soften Sistemas"
            VALUE "FileDescription",  "Soften Phone"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "SPHONE"
            VALUE "OriginalFilename", "SPHONE.exe"
            VALUE "ProductName",      "Soften Phone"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x416, 1200
    END
END
